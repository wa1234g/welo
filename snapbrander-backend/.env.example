# Database Configuration
DATABASE_URL=sqlite:///./snapbrander.db

# JWT Configuration
SECRET_KEY=your-super-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# cPanel Configuration
CPANEL_HOST=https://your-server.com:2083
CPANEL_USER=your-cpanel-username
CPANEL_TOKEN=your-cpanel-api-token
CPANEL_DOMAIN=snapbrander.com

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Payment Gateway (Paymob Egypt)
PAYMOB_API_KEY=your-paymob-api-key
PAYMOB_INTEGRATION_ID=your-integration-id
PAYMOB_HMAC_SECRET=your-hmac-secret

# AI Configuration (OpenAI)
OPENAI_API_KEY=your-openai-api-key

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760  # 10MB

# Domain Registration API
DOMAIN_API_KEY=your-domain-registrar-api-key
DOMAIN_API_URL=https://api.your-domain-provider.com

# WordPress Configuration
WP_CLI_PATH=/usr/local/bin/wp
WP_INSTALL_PATH=/var/www/html/clients
